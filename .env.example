# Required for sessions (iron-session): at least 32 characters.
# Copy this file to .env.local (Next loads it for both dev and next start).
SESSION_PASSWORD=replace-with-a-long-random-secret-at-least-32-chars

# Local-only: if you run `next start` without .env.local, you may set this to 1
# in the shell (never use in production).
# ALLOW_INSECURE_SESSION_PASSWORD=1

# Optional: defaults to ./data/village60.sqlite under this app folder.
# DATABASE_PATH=./data/village60.sqlite

# Internal cron (16b): required for POST /api/internal/cron/generate-monthly-charges
# (Authorization: Bearer <same value>). Omit in dev if you do not call that route.
# CRON_SECRET=replace-with-a-long-random-secret

# Optional: app reporting timezone (defaults to UTC).
# APP_TIMEZONE=UTC

# Optional: destination for `npm run db:backup` (defaults to ./data/backups).
# BACKUP_DIR=./data/backups

# Optional seed overrides (defaults shown).
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=ChangeMeNow!1
